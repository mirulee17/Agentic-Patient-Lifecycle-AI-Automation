{
  "name": "Retention Agent",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst lastVisit = new Date(input.last_visit_date);\nconst now = new Date();\nconst diffTime = now - lastVisit;\nconst diffDays = diffTime / (1000 * 60 * 60 * 24);\nconst inactiveMonths = diffDays / 30;\n\nreturn [\n  {\n    json: {\n      ...input,\n      inactive_months: Number(inactiveMonths.toFixed(1)),\n      is_inactive_6_plus_months: inactiveMonths >= 6\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        0
      ],
      "id": "ea5dcb3c-749d-4d8b-ba78-f493d91a0c33",
      "name": "Check Inactive 6+ Months"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst toBool = (v) => {\n  if (typeof v === 'boolean') return v;\n  if (typeof v === 'string') return v.toLowerCase() === 'true';\n  return Boolean(v);\n};\n\nconst toNum = (v) => {\n  if (typeof v === 'number') return v;\n  const n = Number(v);\n  return Number.isNaN(n) ? 0 : n;\n};\n\nreturn [\n  {\n    json: {\n      ...input,\n      has_messaging_consent: toBool(input.has_messaging_consent),\n      unresolved_clinical_issue: toBool(input.unresolved_clinical_issue),\n      unresolved_billing_issue: toBool(input.unresolved_billing_issue),\n      contacts_this_month: toNum(input.contacts_this_month),\n      chronic_conditions_count: toNum(input.chronic_conditions_count),\n      total_visits: toNum(input.total_visits)\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
