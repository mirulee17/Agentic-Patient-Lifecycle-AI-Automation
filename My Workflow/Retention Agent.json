    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nlet segment = 'one-time';\n\nif (input.chronic_conditions_count >= 1) {\n  segment = 'chronic';\n} else if (input.total_visits >= 2) {\n  segment = 'wellness';\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n      patient_segment: segment\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1872,
        0
      ],
      "id": "69f07681-8a1a-4439-85c3-be5e53572d24",
      "name": "Classify Patient Segment"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nlet message = '';\n\nif (input.patient_segment === 'chronic') {\n  message = `Hi ${input.patient_id}, it’s time for your follow-up care review. We noticed you haven’t visited in a while. Please book your next appointment if you'd like continued support for your ongoing condition management.`;\n} else if (input.patient_segment === 'wellness') {\n  message = `Hi ${input.patient_id}, we haven’t seen you in a while. If you’d like, you can schedule your next wellness visit or routine check-up with the clinic.`;\n} else {\n  message = `Hi ${input.patient_id}, we noticed it has been some time since your last visit. If you need anything, you’re welcome to book an appointment with the clinic.`;\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n      outreach_allowed: true,\n      retention_status: 'ready_to_send',\n      outreach_message: message\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        0
