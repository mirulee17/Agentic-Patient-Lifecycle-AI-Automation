            },
            {
              "id": "7e0b1a3d-4665-4dbd-a43a-8e86df64a1b3",
              "name": "reason",
              "value": "={{ JSON.parse($json[\"ai_raw_text\"]).reason }}",
              "type": "string"
            },
            {
              "id": "756d979a-d8a6-401f-bf7f-a2a99573b17f",
              "name": "guidance",
              "value": "={{ \n  JSON.parse($json[\"ai_raw_text\"]).urgency === \"ROUTINE\"\n    ? \"Your symptoms do not appear to be an emergency. Please monitor them and book a routine appointment if they continue.\"\n    : JSON.parse($json[\"ai_raw_text\"]).urgency === \"SAME_DAY\"\n    ? \"Your symptoms should be reviewed today. Please contact the clinic for a same-day appointment.\"\n    : \"Your symptoms may need urgent medical attention. Please seek urgent medical review as soon as possible.\"\n}}",
              "type": "string"
            },
            {
              "id": "1c910621-3473-49a8-b426-67c1752237bd",
              "name": "disclaimer",
              "value": "This is not a diagnosis. If symptoms worsen or you feel unsafe, seek immediate medical attention.",
              "type": "string"
            }
          ]
        },
