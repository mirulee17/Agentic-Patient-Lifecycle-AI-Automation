          "__rl": true,
          "value": "models/gemini-2.5-flash",
          "mode": "list",
          "cachedResultName": "models/gemini-2.5-flash"
        },
        "messages": {
          "values": [
            {
              "content": "=You are a clinical triage assistant. Based only on the patient's symptom message, classify the case into exactly one of these urgency levels: ROUTINE, SAME_DAY, or URGENT.\n\nRules:\n- ROUTINE = mild, non-urgent symptoms\n- SAME_DAY = symptoms that should be reviewed today but do not appear immediately life-threatening\n- URGENT = concerning symptoms needing urgent medical attention, but not already flagged as emergency by the rule-based check\n\nReturn only valid JSON in this exact format:\n{\n  \"urgency\": \"ROUTINE\",\n  \"reason\": \"short reason\"\n}\n\nPatient message:\n{{$json[\"body\"][\"message\"]}}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.1,
      "position": [
        592,
        224
      ],
      "id": "2c0f7f13-f21c-4740-9160-5db0e6e45826",
      "name": "Message a model",
      "credentials": {
        "googlePalmApi": {
          "id": "PdEBz8arIHP8qNl8",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "9ea7d489-2fbc-4ed8-9bf1-2f1ef343ddd9",
              "name": "ai_raw_text",
              "value": "={{$json[\"content\"][\"parts\"][0][\"text\"].replace(/```json/g, \"\").replace(/```/g, \"\").trim()}}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
