              "leftValue": "={{\n(() => {\n  const text = String($json.symptom_text || '').toLowerCase();\n\n  const hasBreathingEmergency =\n    text.includes(\"can't breathe\") ||\n    text.includes(\"cannot breathe\") ||\n    text.includes(\"can't breathe properly\") ||\n    text.includes(\"difficulty breathing\") ||\n    text.includes(\"shortness of breath\");\n\n  return hasBreathingEmergency;\n})()\n}}",
