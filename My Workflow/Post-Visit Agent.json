          "conditions": [
            {
              "id": "281e6aba-0ecb-45ba-9c2e-a0eca21baa46",
              "leftValue": "={{\n(() => {\n  const text = String($json.symptom_text || '').toLowerCase();\n  const temp = Number($json.temperature_c || 0);\n\n  const hasBleeding =\n    text.includes(\"bleeding\") ||\n    text.includes(\"blood loss\") ||\n    text.includes(\"bleed\");\n\n  const hasMedicationReaction =\n    text.includes(\"rash\") ||\n    text.includes(\"side effect\") ||\n    text.includes(\"allergic reaction\") ||\n    text.includes(\"reaction to medication\") ||\n    text.includes(\"dizziness after medication\");\n\n  const hasWorseningPain =\n    text.includes(\"pain is worse\") ||\n    text.includes(\"worsening pain\") ||\n    text.includes(\"getting more painful\") ||\n    text.includes(\"more pain than yesterday\");\n\n  const hasHighFever =\n    temp > 38.5 ||\n    text.includes(\"39\") ||\n    text.includes(\"39.5\") ||\n    text.includes(\"high fever\");\n\n  return hasBleeding || hasMedicationReaction || hasWorseningPain || hasHighFever;\n})()\n}}",
              "rightValue": "",
